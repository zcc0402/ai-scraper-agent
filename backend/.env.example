# OpenAI API 配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4

# 可选：Azure OpenAI 配置
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# 应用配置
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# 数据库配置
DATABASE_URL=sqlite:///./data/scraper.db

# 文件存储路径
DATA_OUTPUT_DIR=./data/outputs
DATA_CACHE_DIR=./data/cache
DATA_LOG_DIR=./data/logs

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 爬虫配置
SCRAPER_TIMEOUT=300
SCRAPER_MAX_RETRIES=3
SCRAPER_REQUEST_DELAY=1.0

# agent-browser 配置
AGENT_BROWSER_PATH=agent-browser
AGENT_BROWSER_TIMEOUT=60
